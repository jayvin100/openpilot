def sorted_paths(paths):
  return sorted(paths, key=lambda p: str(p))


def walk_files(root, suffixes, recursive=False, exclude_names=()):
  iterator = root.rglob('*') if recursive else root.glob('*')
  out = []
  for path in iterator:
    if not path.is_file() or path.name in exclude_names or path.suffix not in suffixes:
      continue
    if any(part in {'.build', '.gen'} for part in path.relative_to(root).parts):
      continue
    out.append(path)
  return sorted_paths(out)


# Detect Qt - skip build if not available
if arch == "Darwin":
  try:
    brew_prefix = subprocess.check_output(['brew', '--prefix'], encoding='utf8').strip()
    has_qt = os.path.isdir(os.path.join(brew_prefix, "opt/qt@5"))
  except (FileNotFoundError, subprocess.CalledProcessError):
    has_qt = False
else:
  has_qt = shutil.which('qmake') is not None
if not has_qt:
  Return()

