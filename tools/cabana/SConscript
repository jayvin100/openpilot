pj_meta_re = re.compile(r'\b(Q_OBJECT|Q_GADGET|Q_PLUGIN_METADATA)\b')


def safe_target_name(path):
  rel = os.path.splitext(repo_rel(path))[0]
  return re.sub(r'[^A-Za-z0-9_]+', '_', rel)


def ui_header_target(ui_path):
  return repo_rel(plotjuggler_ui_root / f"ui_{Path(ui_path).stem}.h")


def moc_target(header_path):
  return repo_rel(plotjuggler_gen_root / 'moc' / f"moc_{safe_target_name(header_path)}.cpp")


def qrc_target(qrc_path):
  return repo_rel(plotjuggler_gen_root / 'rcc' / f"qrc_{safe_target_name(qrc_path)}.cpp")


def object_target(group, source_path, suffix):
  return repo_rel(plotjuggler_gen_root / 'obj' / group / f"{safe_target_name(source_path)}{suffix}")


def qrc_dependencies(qrc_path):
  deps = [repo_rel(qrc_path)]
  tree = ET.parse(qrc_path)
  for file_elem in tree.findall('.//file'):
    if file_elem.text:
      deps.append(repo_rel(qrc_path.parent / file_elem.text.strip()))
  return deps


def generate_ui_headers(ui_files):
  ui_headers = []
  for ui_path in ui_files:
    ui_headers += pj_env.Command(
      ui_header_target(ui_path),
      repo_rel(ui_path),
      '$QT3_UIC -o $TARGET $SOURCE')
  return ui_headers


def generate_qrc_sources(local_env, qrc_files):
  qrc_sources = []
  for qrc_path in qrc_files:
    resource_name = Path(qrc_path).stem
    qrc_sources += local_env.Command(
      qrc_target(qrc_path),
      qrc_dependencies(qrc_path),
      f'$QT_RCC -name {resource_name} -o $TARGET ${{SOURCES[0]}}')
  return qrc_sources


def generate_moc_sources(local_env, headers, extra_deps):
  moc_sources = []
  for header in headers:
    if not pj_meta_re.search(header.read_text(errors='ignore')):
      continue
    moc_cpp = local_env.Command(
      moc_target(header),
      repo_rel(header),
      '$QT3_MOC $_CPPDEFFLAGS $_CPPINCFLAGS -o $TARGET $SOURCE')
    if extra_deps:
      local_env.Depends(moc_cpp, extra_deps)
    moc_sources += moc_cpp
  return moc_sources


def build_objects(local_env, group, sources, shared, deps):
  builder = local_env.SharedObject if shared else local_env.StaticObject
  suffix = local_env.subst('$SHOBJSUFFIX' if shared else '$OBJSUFFIX')
  objects = []
  for source in sources:
    target = object_target(group, source, suffix)
    obj = builder(target, source)
    if deps:
      local_env.Depends(obj, deps)
    objects += obj
  return objects


def build_static_library(name, cpp_sources, headers, qrc_files=(), cppdefines=()):
  local_env = pj_env.Clone()
  if cppdefines:
    local_env.AppendUnique(CPPDEFINES=list(cppdefines))
  generated_sources = generate_qrc_sources(local_env, qrc_files)
  generated_sources += generate_moc_sources(local_env, headers, pj_ui_headers)
  source_list = [repo_rel(path) for path in cpp_sources] + generated_sources
  objects = build_objects(local_env, name, source_list, shared=False, deps=pj_ui_headers)
  return local_env.Library(repo_rel(plotjuggler_gen_root / 'lib' / name), objects)


def build_shared_library(name, cpp_sources, headers, link_libs, qrc_files=(), ui_deps=True,
                         cppdefines=(), linkflags=()):
  local_env = pj_env.Clone()
  if cppdefines:
    local_env.AppendUnique(CPPDEFINES=list(cppdefines))
  if linkflags:
    local_env['LINKFLAGS'] += list(linkflags)
  local_env['LIBS'] = list(link_libs) + pj_qt_libs
  generated_sources = generate_qrc_sources(local_env, qrc_files)
  generated_sources += generate_moc_sources(local_env, headers, pj_ui_headers if ui_deps else [])
  source_list = [repo_rel(path) for path in cpp_sources] + generated_sources
  objects = build_objects(local_env, name, source_list, shared=True, deps=pj_ui_headers if ui_deps else [])
  return local_env.SharedLibrary(name, objects, FRAMEWORKS=pj_frameworks)


