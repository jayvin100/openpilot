def repo_rel(path):
  path = Path(path)
  try:
    return '#' + str(path.relative_to(repo_root)).replace(os.sep, '/')
  except ValueError:
    return str(path)


def find_system_library(name):
  candidate_dirs = []
  if arch == "Darwin":
    candidate_dirs += [Path(f"{brew_prefix}/lib")]
  else:
    candidate_dirs += [
      Path('/usr/lib/x86_64-linux-gnu'),
      Path('/lib/x86_64-linux-gnu'),
      Path('/usr/lib'),
      Path('/lib'),
      Path('/usr/local/lib'),
    ]

  for directory in candidate_dirs:
    for suffix in ('.so', '.a', '.dylib'):
      candidate = directory / f'lib{name}{suffix}'
      if candidate.exists():
        return File(str(candidate))
  return None


qt_flags = [
  "-D_REENTRANT",
  "-DQT_NO_DEBUG",
  "-DQT_WIDGETS_LIB",
  "-DQT_GUI_LIB",
  "-DQT_CORE_LIB",
  "-DQT_MESSAGELOGCONTEXT",
]

base_qt_modules = ["Widgets", "Gui", "Core"]
pj_qt_modules = base_qt_modules + ["PrintSupport", "Concurrent", "Xml", "Svg", "OpenGL"]

if arch == "Darwin":
  qt_install_prefix = f"{brew_prefix}/opt/qt@5"
  qt_install_headers = os.path.join(qt_install_prefix, "include")
  qt_install_libs = os.path.join(qt_install_prefix, "lib")
  qt_gui_subdir = None
else:
  qt_install_prefix = subprocess.check_output(
      ['qmake', '-query', 'QT_INSTALL_PREFIX'], encoding='utf8').strip()
  qt_install_headers = subprocess.check_output(
      ['qmake', '-query', 'QT_INSTALL_HEADERS'], encoding='utf8').strip()
  qt_install_libs = subprocess.check_output(
      ['qmake', '-query', 'QT_INSTALL_LIBS'], encoding='utf8').strip()
  qt_gui_path = os.path.join(qt_install_headers, "QtGui")
  qt_gui_dirs = [
    d for d in os.listdir(qt_gui_path)
    if os.path.isdir(os.path.join(qt_gui_path, d))
  ]
  qt_gui_subdir = os.path.join(qt_install_headers, "QtGui", qt_gui_dirs[0], "QtGui") if qt_gui_dirs else None
  pj_qt_modules.append("X11Extras")


def make_qt_env(modules, autoscan=True):
  qenv = env.Clone()
  qenv['QTDIR'] = qt_install_prefix
  if arch == "Darwin":
    cpp_dirs = [os.path.join(qenv['QTDIR'], "include")]
    cpp_dirs += [os.path.join(qenv['QTDIR'], "include", f"Qt{module}") for module in modules]
    qenv["LINKFLAGS"] += ["-F" + qt_install_libs]
    qenv["LIBPATH"] += [qt_install_libs]
    qenv["FRAMEWORKS"] += [f"Qt{module}" for module in modules]
    if "OpenGL" in modules:
      qenv["FRAMEWORKS"] += ["OpenGL"]
    qenv.AppendENVPath('PATH', os.path.join(qenv['QTDIR'], "bin"))
    qt_libs = []
  else:
    cpp_dirs = [qt_install_headers]
    if qt_gui_subdir:
      cpp_dirs.append(qt_gui_subdir)
    cpp_dirs += [os.path.join(qt_install_headers, f"Qt{module}") for module in modules]
    qt_libs = [f"Qt5{module}" for module in modules]
    if "OpenGL" in modules:
      qt_libs.append("GL")
    qenv["LIBPATH"] += [qt_install_libs]

  qenv['QT3DIR'] = qenv['QTDIR']
  qenv.Tool('qt3')
  if not autoscan:
    qenv['QT3_AUTOSCAN'] = 0
  qenv['QT_RCC'] = os.path.join(qenv['QTDIR'], 'bin', 'rcc')
  qenv['CPPPATH'] += cpp_dirs
  qenv['CXXFLAGS'] += qt_flags
  qenv['LIBS'] = qt_libs
  return qenv


