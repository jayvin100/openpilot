<?xml version='1.0' encoding='UTF-8'?>
<root>
 <tabbed_widget name="Main Window" parent="main_window">
  <Tab tab_name="Body Speed" containers="1">
   <Container>
    <DockSplitter orientation="-" sizes="1.0" count="1">
     <DockArea name="...">
      <plot flip_y="false" flip_x="false" mode="TimeSeries" style="Lines">
       <range right="0" top="0" left="0" bottom="0"/>
       <limitY/>
       <curve name="speed_desired" color="#1f77b4"/>
       <curve name="speed_measured" color="#d62728"/>
      </plot>
     </DockArea>
    </DockSplitter>
   </Container>
  </Tab>
  <currentTabIndex index="0"/>
 </tabbed_widget>
 <use_relative_time_offset enabled="1"/>
 <!-- - - - - - - - - - - - - - - -->
 <Plugins>
  <plugin ID="DataLoad Rlog"/>
  <plugin ID="Cereal Subscriber"/>
 </Plugins>
 <!-- - - - - - - - - - - - - - - -->
 <customMathEquations>
  <snippet name="speed_desired">
   <global/>
   <function>return value / 5.0</function>
   <linked_source>/carControl/actuators/accel</linked_source>
   <additional_sources/>
  </snippet>
  <snippet name="speed_measured">
   <global/>
   <function>return 0.008587 * (value + v1) / 2.0</function>
   <linked_source>/carState/wheelSpeeds/fl</linked_source>
   <additional_sources>
    <v1>/carState/wheelSpeeds/fr</v1>
   </additional_sources>
  </snippet>
 </customMathEquations>
 <snippets/>
</root>
