+class LiveRGBFiles(MonocularDataset):
+    """Watches a directory for new .npy frames. Reads sequentially for visual continuity."""
+
+    def __init__(self, dataset_path, fps=5, timeout=120):
+        super().__init__()
+        self.use_calibration = False
+        self.save_results = False
+        self.dataset_path = pathlib.Path(dataset_path)
+        self.fps = fps
+        self.timeout = timeout
+
+    def __len__(self):
+        return 999999
+
+    def subsample(self, subsample):
+        pass
+
+    def get_timestamp(self, idx):
+        return idx / self.fps
+
+    def read_img(self, idx):
+        fname = self.dataset_path / f"{idx:06d}.npy"
+
+        # Wait for the frame to appear
+        waited = 0.0
+        while not fname.exists():
+            time.sleep(0.02)
+            waited += 0.02
+            if waited > self.timeout:
+                raise StopIteration(f"Timed out waiting for {fname}")
+
+        # Load raw numpy array (BGR from ffmpeg)
+        img = None
+        for _ in range(20):
+            try:
+                img = np.load(str(fname))
+                break
+            except Exception:
+                time.sleep(0.02)
+        if img is None:
+            raise StopIteration(f"Failed to read {fname}")
+
+        self.timestamps.append(idx / self.fps)
+        return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
+
