+class LiveRGBFiles(MonocularDataset):
+    """Watches a directory for new PNG frames. Blocks until the next frame appears."""
+
+    def __init__(self, dataset_path, fps=10, timeout=60):
+        super().__init__()
+        self.use_calibration = False
+        self.save_results = False
+        self.dataset_path = pathlib.Path(dataset_path)
+        self.fps = fps
+        self.timeout = timeout
+
+    def __len__(self):
+        return 999999
+
+    def subsample(self, subsample):
+        pass
+
+    def get_timestamp(self, idx):
+        return idx / self.fps
+
+    def read_img(self, idx):
+        fname = self.dataset_path / f"{idx:06d}.png"
+        waited = 0.0
+        while not fname.exists():
+            time.sleep(0.05)
+            waited += 0.05
+            if waited > self.timeout:
+                raise StopIteration(f"Timed out waiting for {fname}")
+        # Retry reads — file may still be partially written
+        img = None
+        for _ in range(50):
+            img = cv2.imread(str(fname))
+            if img is not None:
+                break
+            time.sleep(0.05)
+        if img is None:
+            raise StopIteration(f"Failed to read {fname}")
+        self.timestamps.append(idx / self.fps)
+        return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
+
